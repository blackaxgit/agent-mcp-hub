{
  "name": "agent-mcp-hub",
  "version": "0.1.0",
  "description": "One MCP server bridging the Codex, Cursor, OpenCode, and Claude CLI agents",
  "license": "MIT",
  "type": "module",
  "bin": { "agent-mcp-hub": "dist/index.js", "agent-mcp-hub-http": "dist/http.js" },
  "files": ["dist"],
  "engines": { "node": ">=20" },
