node_modules/
dist/
*.log
.env

# Internal process docs (plans, fixes, reviews) — kept local, not pushed
docs/

# test coverage output
coverage/
.stryker-tmp/
reports/

# Proxy CA certificates are environment-specific — never commit them.
# certs/ itself is tracked (README + .gitkeep) so the Dockerfile COPY always resolves.
certs/*
!certs/.gitkeep
!certs/README.md
